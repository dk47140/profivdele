35\u0441\u0442\u044c \u043f\u043e\u043d\u0438\u043c\u0430\u043d\u0438\u0435 \u043e \u043f\u0440\u043e\u0432\u0435\u0434\u0435\u043d\u0438\u0438 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0433\u043e \u0438 \u043a\u043e\u043c\u0444\u043e\u0440\u0442\u043d\u043e\u0433\u043e \u0448\u043e\u0443. \u0422\u0430\u043a\u0436\u0435 \u0443\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0435 \u043f\u0440\u0430\u0432\u0438\u043b\u0430 \u043f\u043e\u0432\u0435\u0434\u0435\u043d\u0438\u044f \u0434\u043b\u044f \u0433\u043e\u0441\u0442\u0435\u0439.<\/p>\n<p><strong>7. \u041f\u043e\u0434\u0445\u043e\u0434\u044f\u0442 \u043b\u0438 \u0441\u0442\u0440\u0438\u043f\u0442\u0438\u0437\u0435\u0440\u044b \u0434\u043b\u044f \u043a\u043e\u0440\u043f\u043e\u0440\u0430\u0442\u0438\u0432\u043e\u0432?<\/strong><\/p>\n<p>\u0414\u0430, \u043c\u043d\u043e\u0433\u0438\u0435 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u044e\u0442 \u0443\u0441\u043b\u0443\u0433\u0438 \u0441\u0442\u0440\u0438\u043f\u0442\u0438\u0437\u0430 \u0434\u043b\u044f \u043a\u043e\u0440\u043f\u043e\u0440\u0430\u0442\u0438\u0432\u043e\u0432, \u043d\u043e \u0441\u0442\u043e\u0438\u0442 \u0443\u0442\u043e\u0447\u043d\u044f\u0442\u044c \u0442\u0435\u043c\u0430\u0442\u0438\u043a\u0443 \u0438 \u0430\u0443\u0434\u0438\u0442\u043e\u0440\u0438\u044e.<\/p>\n<p><strong>8. \u041a\u0430\u043a\u043e\u0432\u0430 \u043f\u0440\u043e\u0434\u043e\u043b\u0436\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u0441\u0442\u0440\u0438\u043f\u0442\u0438\u0437-\u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u0438\u0439?<\/strong><\/p>\n<p>\u041e\u0431\u044b\u0447\u043d\u043e \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u0438\u044f \u0434\u043b\u044f\u0442\u0441\u044f \u043e\u0442 10 \u0434\u043e 30 \u043c\u0438\u043d\u0443\u0442, \u043d\u043e \u043c\u043e\u0433\u0443\u0442 \u0431\u044b\u0442\u044c \u0440\u0430\u0437\u043b\u0438\u0447\u043d