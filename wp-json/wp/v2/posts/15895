\u0442\u043e\u0440\u0430 \u043f\u043e \u0448\u0430\u0445\u043c\u0430\u0442\u0430\u043c \u0432 \u041c\u043e\u0441\u043a\u0432\u0435?<\/strong><\/p>\n<p>\u0412\u044b\u0431\u0438\u0440\u0430\u0439\u0442\u0435 \u0440\u0435\u043f\u0435\u0442\u0438\u0442\u043e\u0440\u0430 \u043f\u043e \u043e\u0442\u0437\u044b\u0432\u0430\u043c, \u0446\u0435\u043d\u0430\u043c \u0438 \u043e\u043f\u044b\u0442\u0443 \u0440\u0430\u0431\u043e\u0442\u044b. \u041e\u0431\u0440\u0430\u0442\u0438\u0442\u0435 \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u0435 \u043d\u0430 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044e \u0438 \u043c\u0435\u0442\u043e\u0434\u0438\u043a\u0438 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f.<\/p>\n<p><strong>2. \u0427\u0442\u043e \u0432\u043a\u043b\u044e\u0447\u0430\u044e\u0442 \u0437\u0430\u043d\u044f\u0442\u0438\u044f \u043f\u043e \u0448\u0430\u0445\u043c\u0430\u0442\u0430\u043c?<\/strong><\/p>\n<p>\u0417\u0430\u043d\u044f\u0442\u0438\u044f \u043c\u043e\u0433\u0443\u0442 \u0432\u043a\u043b\u044e\u0447\u0430\u0442\u044c \u0430\u043d\u0430\u043b\u0438\u0437 \u043f\u0430\u0440\u0442\u0438\u0439, \u0438\u0437\u0443\u0447\u0435\u043d\u0438\u0435 \u0442\u0430\u043a\u0442\u0438\u043a \u0438 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u0439, \u043f\u0441\u0438\u0445\u043e\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u0443\u044e \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0443 \u0438 \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0443 \u043a \u0442\u0443\u0440\u043d\u0438\u0440\u0430\u043c.<\/p>\n<p><strong>3. \u041a\u0430\u043a\u043e\u0432\u0430 \u0441\u0442\u043e\u0438\u043c\u043e\u0441\u0442\u044c \u0443\u0440\u043e\u043a\u043e\u0432 \u043f\u043e \u0448\u0430\u0445\u043c\u0430\u0442\u0430\u043c \u0432 \u041c\u043e\u0441\u043a\u0432\u0435?<\/strong><\/p>\n<p>\u0426\u0435\u043d\u044b \u0432\u0430\u0440\u044c\u0438\u0440\u0443\u044e\u0442\u0441\u044f \u043e\u0442 800 \u0434\u043e 2000 \u0440\u0443\u0431\u043b\u0435\u0439 \u0437\u0430 \u0443\u0440\u043e\u043a, \u0432 \u0437\u0430\u0432\u0438\u0441\u0438\u043c\u043e\u0441\u0442\u0438 \u043e\u0442 \u0440\u0435\u043f\u0435\u0442\u0438\u0442\u043e\u0440\u0430 \u0438 \u0444\u043e\u0440\u043c\u0430\u0442\u0430 \u0437\u0430\u043d\u044f\u0442\u0438\u0439.<\/p>\n<p><strong>4. \u041a\u0430\u043a \u0447\u0430\u0441\u0442\u043e \u043d\u0443\u0436\u043d\u043e \u0437\u0430\u043d\u0438\u043c\u0430\u0442\u044c\u0441\u044f \u0448\u0430\u0445\u043c\u0430\u0442\u0430\u043c\u0438?<\/strong><\/p>\n<p>\u0427\u0430\u0441\u0442\u043e\u0442\u0430 \u0437\u0430\u043d\u044f\u0442\u0438\u0439 \u0437\u0430\u0432\u0438\u0441\u0438\u0442 \u043e\u0442 \u0443\u0440\u043e\u0432\u043d\u044f \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0438 \u0443\u0447\u0435\u043d\u0438\u043a\u0430 \u0438 \u0435\u0433\u043e \u0446\u0435\u043b\u0435\u0439. \u0420\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0443\u0435\u0442\u0441\u044f 1-2 \u0437\u0430\u043d\u044f\u0442\u0438\u044f \u0432 \u043d\u0435\u0434\u0435\u043b\u044e \u0434\u043b\u044f \u0440\u0435\u0433\u0443\u043b\u044f\u0440\u043d\u043e\u0433\u043e \u043f\u0440\u043e\u0433\u0440\u0435\u0441\u0441\u0430.<\/p>\n<p><strong>5. \u041c\u043e\u0436\u043d\u043e \u043b\u0438 \u0443\u0447\u0438\u0442\u044c\u0441\u044f \u0448\u0430\u0445\u043c\u0430\u0442\u0430\u043c \u043e\u043d\u043b\u0430\u0439\u043d?<\/strong><\/p>\n<p>\u0414\u0430, \u043c\u043d\u043e\u0433\u0438\u0435 \u0440\u0435\u043f\u0435\u0442\u0438\u0442\u043e\u0440\u044b \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u044e\u0442 \u043e\u043d\u043b\u0430\u0439\u043d-\u0437\u0430\u043d\u044f\u0442\u0438\u044f \u0447\u0435\u0440\u0435\u0437 \u0432\u0438\u0434\u0435\u043e\u0441\u0432\u044f\u0437\u044c, \u0447\u0442\u043e \u0443\u0434\u043e\u0431\u043d\u043e \u0438 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e.<\/p>\n<p><strong>6. \u041a\u0430\u043a \u0431\u044b\u0441\u0442\u0440\u043e \u043c\u043e\u0436\u043d\u043e \u0434\u043e\u0431\u0438\u0442\u044c\u0441\u044