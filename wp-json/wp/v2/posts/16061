422\u043e\u0440\u0442 \u043d\u0430 8 \u043f\u043e\u0440\u0446\u0438\u0439: \u043e\u0442 5 000 \u0440\u0443\u0431. \u041a\u0430\u043f\u043a\u0435\u0439\u043a\u0438: \u043e\u0442 850 \u0440\u0443\u0431. \u0437\u0430 6 \u0448\u0442. \u0422\u043e\u0440\u0442\u044b \u0441 \u0430\u0432\u0442\u043e\u0440\u0441\u043a\u0438\u043c \u0434\u0438\u0437\u0430\u0439\u043d\u043e\u043c: \u043e\u0442 7 500 \u0440\u0443\u0431. <\/ul>\n<h2>\u0427\u0430\u0441\u0442\u043e \u0437\u0430\u0434\u0430\u0432\u0430\u0435\u043c\u044b\u0435 \u0432\u043e\u043f\u0440\u043e\u0441\u044b \u043e \u0442\u043e\u0440\u0442\u0430\u0445 \u043d\u0430 \u0440\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u0440\u0435\u0431\u0451\u043d\u043a\u0430 \u0432 \u041c\u043e\u0441\u043a\u0432\u0435<\/h2>\n<p><strong>1. \u041a\u0430\u043a \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u0442\u043e\u0440\u0442 \u043d\u0430 \u0440\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u0440\u0435\u0431\u0451\u043d\u043a\u0430?<\/strong><\/p>\n<p>\u0412\u044b\u0431\u0438\u0440\u0430\u044f \u0442\u043e\u0440\u0442, \u043e\u0431\u0440\u0430\u0442\u0438\u0442\u0435 \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u0435 \u043d\u0430 \u0434\u0438\u0437\u0430\u0439\u043d\u044b, \u0432\u043a\u0443\u0441\u044b, \u0438\u043d\u0434\u0438\u0432\u0438\u0434\u0443\u0430\u043b\u044c\u043d\u044b\u0435 \u043f\u0440\u0435\u0434\u043f\u043e\u0447\u0442\u0435\u043d\u0438\u044f \u0440\u0435\u0431\u0435\u043d\u043a\u0430 \u0438 \u0440\u043e\u0434\u043d\u044b\u0445. \u0422\u0430\u043a\u0436\u0435 \u043f\u0440\u043e\u0432\u0435\u0440\u044f\u0439\u0442\u0435 \u043e\u0442\u0437\u044b\u0432\u044b \u043e \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u0435 \u0438\u043b\u0438 \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u0441\u043a\u043e\u0439.<\/p>\n<p><strong>2. \u041a\u0430\u043a\u043e\u0432\u0430 \u0441\u0440\u0435\u0434\u043d\u044f\u044f \u0441\u0442\u043e\u0438\u043c\u043e\u0441\u0442\u044c \u0442\u043e\u0440\u0442\u0430 \u043d\u0430 \u0440\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u0432 \u041c\u043e\u0441\u043a\u0432\u0435?<\/strong><\/p>\n<p>\u0421\u0440\u0435\u0434\u043d\u044f\u044f \u0441\u0442\u043e\u0438\u043c\u043e\u0441\u0442\u044c \u0442\u043e\u0440\u0442\u0430 \u043d\u0430 \u0440\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u0440\u0435\u0431\u0435\u043d\u043a\u0430 \u0432\u0430\u0440\u044c\u0438\u0440\u0443\u0435\u0442\u0441\u044f \u043e\u0442 3 500 \u0434\u043e 7 000 \u0440\u0443\u0431\u043b\u0435\u0439 \u0432 \u0437\u0430\u0432\u0438\u0441\u0438\u043c\u043e\u0441\u0442\u0438 \u043e\u0442 \u0441\u043b\u043e\u0436\u043d\u043e\u0441\u0442\u0438 \u0434\u0438\u0437\u0430\u0439\u043d\u0430 \u0438 \u0432\u0435\u0441\u0430.<\/p>\n<p><strong>3. \u0413\u0434\u0435 \u0437\u0430\u043a\u0430\u0437\u0430\u0442\u044c \u0442\u043e\u0440\u0442 \u043d\u0430 \u0440\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u0440\u0435\u0431\u0451\u043d\u043a\u0430 \u0441 \u0434\u043e\u0441\u0442\u0430\u0432\u043a\u043e\u0439?<\/strong><\/p>\n<p>\u041b\u0443\u0447\u0448\u0435 \u0432\u0441\u0435\u0433\u043e \u0437\u0430\u043a\u0430\u0437\u044b\u0432\u0430\u0442\u044c \u0442\u043e\u0440\u0442 \u043d\u0430 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u0438\u0437\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0445 \u0441\u0430\u0439\u0442\u0430\u0445 \u0438\u043b\u0438 \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u0441\u043a\u0438\u0445, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u044e\u0442 \u0434\u043e\u0441\u0442\u0430\u0432\u043a\u0443 \u043f\u043e \u041c\u043e\u0441\u043a\u0432\u0435, \u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, \u0447\u0435\u0440\u0435\u0437 \u041f\u0420\u041e\u0424\u0418. \u0420\u0423.<\/p>\n<p><strong>4. \u041a\u0430\u043a \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u0443\u043d\u0438\u043a\u0430\u043b\u044c\u043d\u044b\u0439 \u0434\u0438\u0437\u0430\u0439\u043d \u0434\u043b\u044f \u0442\u043e\u0440\u0442\u0430?<\/strong><\/p>\n<p>\u041e\u0431\u0441\u0443\u0434\u0438\u0442\u0435 \u0432\u0430\u0448\u0438 \u0438\u0434\u0435\u0438 \u0441 \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u043e\u043c, \u043f\u043e\u043a\u0430\u0436\u0438\u0442\u0435 \u043f\u0440\u0438\u043c\u0435\u0440\u044b, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0432\u0430\u043c \u043d\u0440\u0430\u0432\u044f\u0442\u0441\u044f, \u0438 \u0432\u044b\u0431\u0435\u0440\u0438\u0442\u0435 \u0441\u0442\u0438\u043b\u044c, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u043f\u043e\u0434\u0445\u043e\u0434\u0438\u0442 \u043a \u0442\u0435\u043c\u0435 \u043f\u0440\u0430\u0437\u0434\u043d\u0438\u043a\u0430.<\/p>\n<p><strong>5. \u041a\u0430\u043a \u0437\u0430\u043a\u0430\u0437\u0430\u0442\u044c \u0442\u043e\u0440\u0442 \u043d\u0430 \u0440\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u0440\u0435\u0431\u0451\u043d\u043a\u0430 \u0447\u0435\u0440\u0435\u0437 \u0438\u043d\u0442\u0435\u0440\u043d\u0435\u0442?<\/strong><\/p>\n<p>\u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0437\u0430\u043a\u0430\u0437\u0430\u0442\u044c \u0442\u043e\u0440\u0442 \u0447\u0435\u0440\u0435\u0437 \u0441\u0430\u0439\u0442\u044b \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u043e\u0432, \u0437\u0430\u043f\u043e\u043b\u043d\u0438\u0442\u044c \u0437\u0430\u044f\u0432\u043a\u0443 \u0438 \u0443\u0442\u043e\u0447\u043d\u0438\u0442\u044c \u0434\u0435\u0442\u0430\u043b\u0438 \u0434\u043e\u0441\u0442\u0430\u0432\u043a\u0438 \u0438 \u043e\u0444\u043e\u0440\u043c\u043b\u0435\u043d\u0438\u0435 \u043d\u0435\u043f\u043e\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0435\u043d\u043d\u043e \u0441 \u043c\u0430\u0441\u0442\u0435\u0440\u043e\u043c.<\/p>\n<p><strong>6. \u041a\u0430\u043a \u0434\u0430\u0432\u0430\u0442\u044c \u043e\u0442\u0437\u044b\u0432\u044b \u043e \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u0435 \u0438\u043b\u0438 \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u0441\u043a\u043e\u0439?<\/strong><\/p>\n<p>\u041f\u043e\u0441\u043b\u0435 \u043f\u043e\u043b\u0443\u0447\u0435\u043d\u0438\u044f \u0432\u0430\u0448\u0435\u0433\u043e \u0437\u0430\u043a\u0430\u0437\u0430 \u043e\u0441\u0442\u0430\u0432\u044c\u0442\u0435 \u043e\u0442\u0437\u044b\u0432\u044b \u043d\u0430 \u0441\u0430\u0439\u0442\u0430\u0445 \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u043e\u0432, \u0430 \u0442\u0430\u043a\u0436\u0435 \u0432 \u0441\u043e\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0445 \u0441\u0435\u0442\u044f\u0445 \u0438 \u043d\u0430 \u043f\u043b\u043e\u0449\u0430\u0434\u043a\u0430\u0445 \u0442\u0438\u043f\u0430 \u041f\u0420\u041e\u0424\u0418. \u0420\u0423.<\/p>\n<p><strong>7. \u0415\u0441\u0442\u044c \u043b\u0438 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u044c \u043f\u0440\u043e\u0431\u043e\u0432\u0430\u0442\u044c \u0442\u043e\u0440\u0442 \u043f\u0435\u0440\u0435\u0434 \u043f\u043e\u043a\u0443\u043f\u043a\u043e\u0439?<\/strong><\/p>\n<p>\u041d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u0441\u043a\u0438\u0435 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u044e\u0442 \u0434\u0435\u0433\u0443\u0441\u0442\u0430\u0446\u0438\u0438 \u043f\u0435\u0440\u0435\u0434 \u043f\u043e\u043a\u0443\u043f\u043a\u043e\u0439, \u0443\u0442\u043e\u0447\u043d\u044f\u0439\u0442\u0435 \u044d\u0442\u043e\u0442 \u0432\u043e\u043f\u0440\u043e\u0441 \u043f\u0440\u0438 \u0437\u0430\u043a\u0430\u0437\u0435 \u0442\u043e\u0440\u0442\u0430.<\/p>\n<p><strong>8. \u0427\u0442\u043e \u0434\u0435\u043b\u0430\u0442\u044c, \u0435\u0441\u043b\u0438 \u0442\u043e\u0440\u0442 \u043d\u0435 \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u0435\u0442 \u043e\u0436\u0438\u0434\u0430\u043d\u0438\u044f\u043c?<\/strong><\/p>\n<p>\u041e\u0431\u0441\u0443\u0434\u0438\u0442\u0435 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0443 \u0441 \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u043e\u043c, \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e, \u043e\u043d \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0438\u0442 \u0440\u0435\u0448\u0435\u043d\u0438\