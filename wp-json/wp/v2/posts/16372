\u043a\u0430\u043a \u043f\u0440\u0430\u0432\u0438\u043b\u043e, \u043e\u0442 900 \u0440\u0443\u0431. \u0434\u043e 2000 \u0440\u0443\u0431. \u0437\u0430 \u0447\u0430\u0441.<\/p>\n<p><strong>4. \u0415\u0441\u0442\u044c \u043b\u0438 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u044c \u043f\u0440\u043e\u0431\u043d\u043e\u0433\u043e \u0437\u0430\u043d\u044f\u0442\u0438\u044f?<\/strong><\/p>\n<p>\u041c\u043d\u043e\u0433\u0438\u0435 \u0440\u0435\u043f\u0435\u0442\u0438\u0442\u043e\u0440\u044b \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u044e\u0442 \u043f\u0440\u043e\u0431\u043d\u044b\u0435 \u0437\u0430\u043d\u044f\u0442\u0438\u044f, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u043e\u043c\u043e\u0433\u0443\u0442 \u0432\u0430\u043c \u043f\u043e\u043d\u044f\u0442\u044c, \u043f\u043e\u0434\u0445\u043e\u0434\u0438\u0442 \u043b\u0438 \u043c\u0435\u0442\u043e\u0434\u0438\u043a\u0430 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f.<\/p>\n<p><strong>5. \u041a\u0430\u043a \u0431\u044b\u0441\u0442\u0440\u043e \u043c\u043e\u0436\u043d\u043e \u0443\u0432\u0438\u0434\u0435\u0442\u044c \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u044b \u0437\u0430\u043d\u044f\u0442\u0438\u0439?<\/strong><\/p>\n<p>\u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u044b \u0437\u0430\u0432\u0438\u0441\u044f\u0442 \u043e\u0442 \u0432\u0430\u0448\u0435\u0433\u043e \u0443\u0441\u0435\u0440\u0434\u0438\u044f \u0438 \u043f\u043e\u0441\u0442\u043e\u044f\u043d\u0441\u0442\u0432\u0430 \u0432 \u0438\u0437\u0443\u0447\u0435\u043d\u0438\u0438, \u043d\u043e \u0437\u043d\u0430\u0447\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u043f\u0440\u043e\u0433\u0440\u0435\u0441\u0441 \u043e\u0431\u044b\u0447\u043d\u043e \u0432\u0438\u0434\u0435\u043d \u0447\u0435\u0440\u0435\u0437 4-6 \u0437\u0430\u043d\u044f\u0442\u0438\u0439.<\/p>\n<p><strong>6. \u0412\u043e\u0437\u043c\u043e\u0436\u043d\u043e \u043b\u0438 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u0435 \u043e\u043d\u043b\u0430\u0