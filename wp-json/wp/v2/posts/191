u043e \u0443\u0445\u043e\u0434\u0443.<\/p>\n<p><strong>5. \u041a\u0430\u043a\u043e\u0439 \u0443\u0445\u043e\u0434 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c \u0437\u0430 \u0442\u0430\u0442\u0443\u0430\u0436\u0435\u043c \u0433\u0443\u0431?<\/strong><\/p>\n<p>\u041d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u0438\u0437\u0431\u0435\u0433\u0430\u0442\u044c \u0441\u043e\u043b\u043d\u0435\u0447\u043d\u043e\u0433\u043e \u0441\u0432\u0435\u0442\u0430, \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0435 \u043a\u0440\u0435\u043c\u044b \u0438 \u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u044c \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0430\u0446\u0438\u044f\u043c \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u0438\u0441\u0442\u043e\u0432 \u043f\u043e \u0443\u0445\u043e\u0434\u0443.<\/p>\n<p><strong>6. \u041c\u043e\u0436\u043d\u043e \u043b\u0438 \u0434\u0435\u043b\u0430\u0442\u044c \u043a\u043e\u0440\u0440\u0435\u043a\u0446\u0438\u044e \u043f\u043e\u0441\u043b\u0435 \u0442\u0430\u0442\u0443\u0430\u0436\u0430 \u0433\u0443\u0431?<\/strong><\/p>\n<p>\u0414\u0430, \u043a\u043e\u0440\u0440\u0435\u043a\u0446\u0438\u044e \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0443\u0435\u0442\u0441\u044f \u0434\u0435\u043b\u0430\u0442\u044c \u0447\u0435\u0440\u0435\u0437 4-6 \u043d\u0435\u0434\u0435\u043b\u044c \u043f\u043e\u0441\u043b\u0435 \u043f\u0435\u0440\u0432\u0438\u0447\u043d\u043e\u0439 \u043f\u0440\u043e\u0446\u0435\u0434\u0443\u0440\u044b \u0434\u043b\u044f \u0434\u043e\u0441\u0442\u0438\u0436\u0435\u043d\u0438\u044f \u0438\u0434\u0435\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0430.<\/p>\n<p><strong>7. \u041a\u0430\u043a \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u0446\u0432\u0435\u0442 \u0434\u043b\u044f \u0442\u0430\u0442\u0443\u0430\u0436\u0430 \u0433\u0443\u0431?<\/strong><\/p>\n<p>\u0426\u0432\u0435\