\u0439\u043a.<\/p>\n<p><strong>5. \u041c\u043e\u0436\u043d\u043e \u043b\u0438 \u0437\u0430\u043a\u0430\u0437\u0430\u0442\u044c \u0442\u043e\u0440\u0442 \u0431\u0435\u0437 \u0441\u0430\u0445\u0430\u0440\u0430 \u0438\u043b\u0438 \u043d\u0430 \u0434\u0438\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0438\u043d\u0433\u0440\u0435\u0434\u0438\u0435\u043d\u0442\u044b?<\/strong><\/p>\n<p>\u0414\u0430, \u043c\u043d\u043e\u0433\u0438\u0435 \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u044b \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u044e\u0442 \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u044b \u0442\u043e\u0440\u0442\u043e\u0432 \u0431\u0435\u0437 \u0441\u0430\u0445\u0430\u0440\u0430 \u0438\u043b\u0438 \u043d\u0430 \u043e\u0441\u043d\u043e\u0432\u0435 \u0434\u0438\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0438\u043d\u0433\u0440\u0435\u0434\u0438\u0435\u043d\u0442\u043e\u0432. \u041e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e \u0443\u0442\u043e\u0447\u043d\u044f\u0439\u0442\u0435 \u044d\u0442\u043e\u0442 \u043c\u043e\u043c\u0435\u043d\u0442 \u043f\u0440\u0438 \u0437\u0430\u043a\u0430\u0437\u0435.<\/p>\n<p><strong>6. \u041a\u0430\u043a\u043e\u0432\u0430 \u0441\u0440\u0435\u0434\u043d\u044f\u044f \u0446\u0435\u043d\u0430 \u043d\u0430 \u0442\u043e\u0440\u0442 \u043d\u0430 18 \u043b\u0435\u0442 \u0432 \u041c\u043e\u0441\u043a\u0432\u0435?<\/strong><\/p>\n<p>\u0421\u0440\u0435\u0434\u043d\u044f\u044f \u0446\u0435\u043d\u0430 \u043d\u0430 \u0442\u043e\u0440\u0442 \u043d\u0430 18 \u043b\u0435\u0442 \u0432\u0430\u0440\u044c\u0438\u0440\u0443\u0435\u0442\u0441\u044f \u043e\u0442 3 200 \u0434\u043e 12 000 \u0440\u0443\u0431. \u0432 \u0437\u0430\u0432\u0438\u0441\u0438\u043c\u043e\u0441\u0442\u0438 \u043e\u0442 \u0441\u043b\u043e\u0436\u043d\u043e\u0441\u0442\u0438 \u0438 \u043e\u0444\u043e\u0440\u043c\u043b\u0435\u043d\u0438\u044f.<\/p>\n<p><strong>7. \u041c\u043e\u0436\u043d\u043e \u043b\u0438 \u043f\u043e\u043f\u0440\u043e\u0431\u043e