8\u0437\u0430\u0439\u043d\u043e\u043c?<\/strong><\/p>\n<p>\u0414\u0430, \u043c\u043d\u043e\u0433\u0438\u0435 \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u0441\u043a\u0438\u0435 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u044e\u0442 \u0443\u0441\u043b\u0443\u0433\u0438 \u043f\u043e \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044e \u0442\u043e\u0440\u0442\u043e\u0432 \u0441 \u0438\u043d\u0434\u0438\u0432\u0438\u0434\u0443\u0430\u043b\u044c\u043d\u044b\u043c \u0434\u0438\u0437\u0430\u0439\u043d\u043e\u043c.<\/p>\n<p><strong>6. \u041a\u0430\u043a \u043f\u0440\u043e\u0438\u0441\u0445\u043e\u0434\u0438\u0442 \u0434\u043e\u0441\u0442\u0430\u0432\u043a\u0430 \u0442\u043e\u0440\u0442\u043e\u0432 \u043d\u0430 \u044e\u0431\u0438\u043b\u0435\u0439 \u0432 \u041c\u043e\u0441\u043a\u0432\u0435?<\/strong><\/p>\n<p>\u0411\u043e\u043b\u044c\u0448\u0438\u043d\u0441\u0442\u0432\u043e \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u0441\u043a\u0438\u0445 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u044e\u0442 \u0434\u043e\u0441\u0442\u0430\u0432\u043a\u0443, \u043a\u043e\u0442\u043e\u0440\u0430\u044f \u043c\u043e\u0436\u0435\u0442 \u0431\u044b\u0442\u044c \u0431\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u043e\u0439 \u0438\u043b\u0438 \u043f\u043b\u0430\u0442\u043d\u043e\u0439 \u0432 \u0437\u0430\u0432\u0438\u0441\u0438\u043c\u043e\u0441\u0442\u0438 \u043e\u0442 \u0440\u0430\u0441\u0441\u0442\u043e\u044f\u043d\u0438\u044f.<\/p>\n<p><strong>7. \u041a\u0430\u043a\u043e\u0439 \u0432\u043a\u0443\u0441 \u0442\u043e\u0440\u0442\u0430 \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u0434\u043b\u044f \u044e\u0431\u0438\u043b\u0435\u044f 60 \u043b\u0435\u0442?<\/strong><\/p>\n<p>\u041f\u043e\u043f\u0443\u043b\u044f\u0440\u043d\u044b\u0435 \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u044b &#8212; \u0448\u043e\u043a\u043e\u043b\u0430\u0434\u043d\u044b\u0439, \u0432\u0430\u043d\u0438\u043b\u044c\u043d\u044b\u0439, \u0444\u0440\u0443\u043a\u0442\u043e\u0432\u044b\u0439 \u0438 \u0439\u043