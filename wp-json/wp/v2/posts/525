3e\u0436\u043d\u043e\u0441\u0442\u0438 \u0434\u0438\u0437\u0430\u0439\u043d\u0430 \u0438 \u0440\u0430\u0437\u043c\u0435\u0440\u0430 \u0442\u043e\u0440\u0442\u0430.<\/p>\n<p><strong>4. \u041a\u0430\u043a \u0434\u043e\u043b\u0433\u043e \u043d\u0443\u0436\u043d\u043e \u0437\u0430\u0440\u0430\u043d\u0435\u0435 \u0437\u0430\u043a\u0430\u0437\u044b\u0432\u0430\u0442\u044c \u0442\u043e\u0440\u0442 \u0441 \u043d\u0430\u0434\u043f\u0438\u0441\u044c\u044e?<\/strong><\/p>\n<p>\u0420\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0443\u0435\u0442\u0441\u044f \u0437\u0430\u043a\u0430\u0437\u044b\u0432\u0430\u0442\u044c \u043c\u0438\u043d\u0438\u043c\u0443\u043c \u0437\u0430 3-5 \u0434\u043d\u0435\u0439 \u0434\u043e \u043c\u0435\u0440\u043e\u043f\u0440\u0438\u044f\u0442\u0438\u044f, \u0447\u0442\u043e\u0431\u044b \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0438\u0442\u044c \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u0435 \u0437\u0430\u043a\u0430\u0437\u0430 \u0432 \u0441\u0440\u043e\u043a.<\/p>\n<p><strong>5. \u0415\u0441\u0442\u044c \u043b\u0438 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u044c \u0434\u043e\u0441\u0442\u0430\u0432\u043a\u0438 \u0442\u043e\u0440\u0442\u0430 \u043d\u0430 \u0434\u043e\u043c?<\/strong><\/p>\n<p>\u0414\u0430, \u043c\u043d\u043e\u0433\u0438\u0435 \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u0441\u043a\u0438\u0435 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u044e\u0442 \u0443\u0441\u043b\u0443\u0433\u0438 \u0434\u043e\u0441\u0442\u0430\u0432\u043a\u0438, \u0447\u0442\u043e \u043e\u0433\u0440\u0430\u0436\u0434\u0430\u0435\u0442 \u0432\u0430\u0441 \u043e\u0442 \u043b\u0438\u0448\u043d\u0438\u0445 \u0445\u043b\u043e\u043f\u043e\u0442.<\/p>\n<p><strong>6. \u041c\u043e\u0433\u0443 \u043b\u0438 \u044f \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u043d\u0430\u0447\u0438\u043d\u043a\u0443 \u0434\u043b\u044f \u0442\u043e\u0440\u0442\u0430 \u0441 \u043d\u0430\u0434\u043f\u0438\u0441\u044c\u044e?<\/strong><\/p>\n<p>\u0411\u043e\u043b\u044c\u0448\u0438\u043d\u0441\u0442\u0432\u043e \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u0441\u043a\u0438\u0445 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u044e\u0442 \u0432\u044b\u0431\u043e\u0440 \u043d\u0430\u0447\u0438\u043d\u043a\u0438, \u043e\u0442 \u043a\u043b\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0448\u043e\u043a\u043e\u043b\u0430\u0434\u0430 \u0434\u043e \u0444\u0440\u0443\u043a\u0442\u043e\u0432\u044b\u0445 \u0438 \u043a\u0440\u0435\u043c\u043e\u0432\u044b\u0445 \u043d\u0430\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u0439.<\/p>\n<p><strong>7. \u041a\u0430\u043a\u043e\u0439 \u043c\u0438\u043d\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u0435\u0441 \u0442\u043e\u0440\u0442\u0430 \u0434\u043b\u044f \u0437\u0430\u043a\u0430\u0437\u0430?<\/strong><\/p>\n<p>\u041c\u0438\u043d\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u0435\u0441 \u0432\u0430\u0440\u044c\u0438\u0440\u0443\u0435\u0442\u0441\u044f \u043e\u0442 1 \u0434\u043e 3 \u043a\u0433 \u0432 \u0437\u0430\u0432\u0438\u0441\u0438\u043c\u043e\u0441\u0442\u0438 \u043e\u0442 \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u0441\u043a\u043e\u0439 \u0438 \u0442\u0438\u043f\u0430 \u0442\u043e\u0440\u0442\u0430.<\/p>\n<p><strong>8. \u041c\u043e\u0436\u043d\u043e \u043b\u0438 \u0437\u0430\u043a\u0430\u0437\u0430\u0442\u044c \u0442\u043e\u0440\u0442 \u0434\u043b\u044f \u0434\u0438\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u043f\u0438\u0442\u0430\u043d\u0438\u044f?<\/strong><\/p>\n<p>\u041d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043a\u043e\u043d\u0434\u0438\u0442\u0435\u0440\u0430 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u044e\u0442 \u043d\u0438\u0437\u043a\u043e\u043a\u0430\u043b\u043e\u0440\u0438\u0439\u043d\u044b\u0435 \u0438\u043b\u0438 \u0431\u0435\u0437\u0433\u043b\u044e\u0442\u0435\u043d\u043e\u0432\u044b\u0435 \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u044b \u0442\u043e\u0440\u0442\u043e\u0432, \u043d\