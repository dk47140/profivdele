u0430\u0441\u0441\u0430\u0436 \u043f\u043e\u043c\u043e\u0433\u0430\u0435\u0442 \u0441\u043d\u044f\u0442\u044c \u043d\u0430\u043f\u0440\u044f\u0436\u0435\u043d\u0438\u0435, \u0443\u043b\u0443\u0447\u0448\u0438\u0442\u044c circulation, \u0430 \u0442\u0430\u043a\u0436\u0435 \u043c\u043e\u0436\u0435\u0442 \u043b\u0435\u0447\u0438\u0442\u044c \u0431\u043e\u043b\u0435\u0432\u044b\u0435 \u0441\u0438\u043d\u0434\u0440\u043e\u043c\u044b.<\/p>\n<p><strong>5. \u041a\u0430\u043a \u0437\u0430\u043f\u0438\u0441\u0430\u0442\u044c\u0441\u044f \u043d\u0430 \u043c\u0430\u0441\u0441\u0430\u0436 \u0432 \u0427\u0435\u043b\u044f\u0431\u0438\u043d\u0441\u043a\u0435?<\/strong><\/p>\n<p>\u0417\u0430\u043f\u0438\u0441\u0430\u0442\u044c\u0441\u044f \u043c\u043e\u0436\u043d\u043e \u0447\u0435\u0440\u0435\u0437 \u0441\u0430\u0439\u0442 \u043c\u0430\u0441\u0441\u0430\u0436\u043d\u043e\u0433\u043e \u043a\u0430\u0431\u0438\u043d\u0435\u0442\u0430 \u0438\u043b\u0438 \u043f\u043e\u0437\u0432\u043e\u043d\u0438\u0432 \u043d\u0430\u043f\u0440\u044f\u043c\u0443\u044e, \u0431\u043e\u043b\u044c\u0448\u0438\u043d\u0441\u0442\u0432\u043e \u0441\u0435\u0440\u0432\u0438\u0441\u043e\u0432 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u044e\u0442 \u043e\u043d\u043b\u0430\u0439\u043d-\u0437\u0430\u043f\u0438\u0441\u044c.<\/p>\n<p><strong>6. \u041c\u043e\u0433\u0443 \u043b\u0438 \u044f \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u043c\u0430\u0441\u0441\u0430\u0436\u0438\u0441\u0442\u0430?<\/strong><\/p>\n<p>\u0414\u0430, \u043c\u043d\u043e\u0433\u0438\u0435 \u0441\u0430\u043b\u043e\u043d\u044b \u0438 \u0441\u0442\u0443\u0434\u0438\u0438 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u044e\u0442 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u044c \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u043c\u0430\u0441\u0441\u0430\u0436\u0438\u0441\u0442\u0430, \u043e\u0441\u043d\u043e\u0432\u044b\u0432\u0430\u044f\u0441\u044c \u043d\u0430 \u043e\u0442\u0437\u044b\u0432\u0430\u0445 \u0438 \u043a\u0432\u0430\u043b\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u0438.<\/p>\n<p><strong>7. \u041a\u0430\u043a \u0447\u0430\u0441\u0442\u043e \u043d\u0443\u0436\u043d\u043e \u0434\u0435\u043b\u0430\u0442\u044c \u043c\u0430\u0441\u0441\u0430\u0436?<\/strong><\/p>\n<p>\u0427\u0430\u0441\u0442\u043e\u0442\u0430 \u0441\u0435\u0430\u043d\u0441\u043e\u0432 \u0437\u0430\u0432\u0438\u0441\u0438\u0442 \u043e\u0442 \u0432\u0430\u0448\u0438\u0445 \u0446\u0435\u043b\u0435\u0439 \u0438 \u0441\u043e\u0441\u0442\u043e\u044f\u043d\u0438\u044f \u0437\u0434\u043e\u0440\u043e\u0432\u044c\u044f, \u043d\u043e \u043e\u0431\u044b\u0447\u043d\u043e \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0443\u0435\u0442\u0441\u044f \u043a\u0443\u0440\u0441 \u0438\u0437 5-10 \u0441\u0435\u0430\u043d\u0441\u043e\u0432.<\/p>\n<p><strong>8. \u041d\u0443\u0436\u043d\u0430 \u043b\u0438 \u043a\u043e\u043d\u0441\u0443\u043b\u044c\u0442\u0430\u0446\u0438\u044f \u043f\u0435\u0440\u0435\u0434 \u043c\u0430\u0441\u0441\u0430\u0436\u0435\u043c?<\/strong><\/p>\n<p>\u0414\u0430, \u043f\u0435\u0440\u0435\u0434 \u043f\u0435\u0440\u0432\u044b\u043c \u0441\u0435\u0430\u043d\u0441\u043e\u043c \u0436\u0435\u043b\u0430\u0442\u0435\u043b\u044c\u043d\u043e \u043f\u0440\u043e\u043a\u043e\u043d\u0441\u0443\u043b\u044c\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c\u0441\u044f \u0441 \u043c\u0430\u0441\u0441\u0430\u0436\u0438\u0441\u0442\u043e\u043c, \u0447\u0442\u043e\u0431\u044b \u043e\u0431\u0441\u0443\u0434\u0438\u0442\u044c \u0432\u0430\u0448\u0438 \u043e\u0436\u0438\u0434\u0430\u043d\u0438\u044f \u0438 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u044b.<\/p>\n<p><strong>9. \u041a\u0430\u043a\u043e\u0432\u043e \u0432\u043b\u0438\u044f\u043d\u0438\u0435 \u043c\u0430\u0441\u0441\u0430\u0436\u0430 \u043d\u0430 \u0437\u0434\u043e\u0440\u043e\u0432\u044c\u0435?<\/strong><\/p>\n<p>\u041c\u0430\u0441\u0441\u0430\u0436 \u043c\u043e\u0436\u0435\u0442 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e \u0443\u043b\u0443\u0447\u