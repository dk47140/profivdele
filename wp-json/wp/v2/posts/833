3e\u0432\u043a\u0430 \u043e\u0441\u043d\u043e\u0432\u0430\u043d\u0438\u044f \u043e\u0447\u0435\u043d\u044c \u0432\u0430\u0436\u043d\u0430. \u042d\u0442\u043e \u043c\u043e\u0436\u0435\u0442 \u0432\u043a\u043b\u044e\u0447\u0430\u0442\u044c \u0432 \u0441\u0435\u0431\u044f \u0432\u044b\u0440\u0430\u0432\u043d\u0438\u0432\u0430\u043d\u0438\u0435 \u0438 \u043e\u0447\u0438\u0449\u0435\u043d\u0438\u0435 \u043f\u043e\u0432\u0435\u0440\u0445\u043d\u043e\u0441\u0442\u0438.<\/p>\n<p><strong>5. \u041a\u0430\u043a\u043e\u0439 \u0442\u0438\u043f \u043f\u043b\u0438\u0442\u043a\u0438 \u043b\u0443\u0447\u0448\u0435 \u0432\u044b\u0431\u0438\u0440\u0430\u0442\u044c \u0434\u043b\u044f \u0432\u0430\u043d\u043d\u043e\u0439?<\/strong><\/p>\n<p>\u0420\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0443\u0435\u0442\u0441\u044f \u0432\u044b\u0431\u0438\u0440\u0430\u0442\u044c \u0432\u043b\u0430\u0433\u043e\u0441\u0442\u043e\u0439\u043a\u0443\u044e \u043f\u043b\u0438\u0442\u043a\u0443 \u0441 \u0430\u043d\u0442\u0438\u0441\u043a\u043e\u043b\u044c\u0437\u044f\u0449\u0435\u0439 \u043f\u043e\u0432\u0435\u0440\u0445\u043d\u043e\u0441\u0442\u044c\u044e \u0434\u043b\u044f \u043f\u043e\u0432\u044b\u0448\u0435\u043d\u0438\u044f \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438.<\/p>\n<p><strong>6. \u041a\u0430\u043a\u0438\u0435 \u0431\u044b\u0432\u0430\u044e\u0442 \u0441\u043f\u043e\u0441\u043e\u0431\u044b \u0443\u043a\u043b\u0430\u0434\u043a\u0438 \u043f\u043b\u0438\u0442\u043a\u0438?<\/strong><\/p>\n<p>\u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044e\u0442 \u0440\u0430\u0437\u043b\u0438\u0447\u043d\u044b\u0435 \u0441\u0445\u0435\u043c\u044b \u0443\u043a\u043b\u0430\u0434\u043a\u0438, \u0442\u0430\u043a\u0438\u0435 \u043a\u0430\u043a \u00ab\u0432 \u0435\u043b\u043e\u0447\u043a\u0443\u00bb, \u0434\u0438\u0430\u0433\u043e\u043d\u0430\u043b\u044c\u043d\u0430\u044f \u0443\u043a\u043b\u0430\u0434\u043a\u0430 \u0438 \u043f\u0440\u044f\u043c\u0430\u044f, \u043a\u0430\u0436\u0434\u0430\u044f \u0438\u0437 \u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u0432\u043b\u0438\u044f\u0435\u0442 \u043d\u0430 \u0432\u0438\u0437\u0443\u0430\u043b\u044c\u043d\u043e\u0435 \u0432\u043e\u0441\u043f\u0440\u0438\u044f\u0442\u0438\u0435.<\/p>\n<p><strong>7. \u041c\u043e\u0433\u0443 \u043b\u0438 \u044f \u0443\u043a\u043b\u0430\u0434\u044b\u0432\u0430\u0442\u044c \u043f\u043b\u0438\u0442\u043a\u0443 \u0441\u0430\u043c?<\/strong><\/p>\n<p>\u0414\u0430, \u0435\u0441\u043b\u0438 \u0443 \u0432\u0430\u0441 \u0435\u0441\u0442\u044c \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044e\u0449\u0438\u0439 \u043e\u043f\u044b\u0442 \u0438 \u043d\u0430\u0432\u044b\u043a\u0438, \u043e\u0434\u043d\u0430\u043a\u043e \u043b\u0443\u0447\u0448\u0435 \u0434\u043e\u0432\u0435\u0440\u0438\u0442\u044c \u044d\u0442\u0443 \u0440\u0430\u0431\u043e\u0442\u0443 \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u0430\u043c \u0434\u043b\u044f \u0438\u0437\u0431\u0435\u0436\u0430\u043d\u0438\u044f \u043e\u0448\u0438\u0431\u043e\u043a.<\/p>\n<p><strong>8. \u041a\u0430\u043a \u0443\u0445\u0430\u0436\u0438\u0432\u0430\u0442\u044c \u0437\u0430 \u043f\u043b\u0438\u0442\u043a\u043e\u0439 \u0432 \u0432\u0430\u043d\u043d\u043e\u0439?<\/strong><\/p>\n<p>\u041d\u0430\u0434\u043e \u0440\u0435\u0433\u0443\u043b\u044f\u0440\u043d\u043e \u043c\u044b\u0442\u044c \u043f\u043b\u0438\u0442\u043a\u0443 \u0441 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435\u043c \u043c\u044f\u0433\u043a\u0438\u0445 \u043c\u043e\u044e\u0449\u0438\u0445 \u0441\u0440\u0435\u0434\u0441\u0442\u0432 \u0438 \u0438\u0437\u0431\u0435\u0433\u0430\u0442\u044c \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u044f \u0430\u0431\u0440\u0430\u0437\u0438\u0432\u043d\u044b\u0445 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u043e\u0432.<\/p>\n<p><strong>9. \u041a\u0430\u043a\u0443\u044e \u0448\u043f\u0430\u0442\u043b\u0435\u0432\u043a\u0443 \u0432\u044