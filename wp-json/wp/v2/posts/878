\u0443\u0433\u0438 \u043a\u043e\u0441\u043c\u0435\u0442\u043e\u043b\u043e\u0433\u0430 \u0432 \u041c\u043e\u0441\u043a\u0432\u0435?<\/strong><\/p>\n<p>\u0426\u0435\u043d\u044b \u0437\u0430\u0432\u0438\u0441\u044f\u0442 \u043e\u0442 \u043a\u043e\u043d\u043a\u0440\u0435\u0442\u043d\u044b\u0445 \u043f\u0440\u043e\u0446\u0435\u0434\u0443\u0440 \u0438 \u0443\u0440\u043e\u0432\u043d\u044f \u043a\u043b\u0438\u043d\u0438\u043a\u0438. \u0412 \u0441\u0440\u0435\u0434\u043d\u0435\u043c \u0441\u0442\u043e\u0438\u043c\u043e\u0441\u0442\u044c \u0443\u0441\u043b\u0443\u0433 \u0432\u0430\u0440\u044c\u0438\u0440\u0443\u0435\u0442\u0441\u044f \u043e\u0442 2 500 \u0434\u043e 20 000 \u0440\u0443\u0431\u043b\u0435\u0439.<\/p>\n<p><strong>4. \u041a\u0430\u043a \u0447\u0430\u0441\u0442\u043e \u043d\u0443\u0436\u043d\u043e \u043f\u043e\u0441\u0435\u0449\u0430\u0442\u044c \u043a\u043e\u0441\u043c\u0435\u0442\u043e\u043b\u043e\u0433\u0430?<\/strong><\/p>\n<p>\u0427\u0430\u0441\u0442\u043e\u0442\u0430 \u043f\u043e\u0441\u0435\u0449\u0435\u043d\u0438\u0439 \u0437\u0430\u0432\u0438\u0441\u0438\u0442 \u043e\u0442 \u0442\u0438\u043f\u0430 \u043f\u0440\u043e\u0446\u0435\u0434\u0443\u0440. \u041d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u0440\u043e\u0446\u0435\u0434\u0443\u0440\u044b \u0442\u0440\u0435\u0431\u0443\u044e\u0442 \u0440\u0435\u0433\u0443\u043b\u044f\u0440\u043d\u043e\u0441\u0442\u0438, \u0432 \u0442\u043e \u0432\u0440\u0435\u043c\u044f \u043a\u0430\u043a \u0434\u0440\u0443\u0433\u0438\u0435 \u2013 \u043e\u0434\u043d\u043e\u043a\u0440\u0430\u0442\u043d\u044b\u0435.<\/p>\n<p><strong>5. \u0411\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u044b \u043b\u0438 \u0438\u043d\u044a\u0435\u043a\u0446\u0438\u0438 \u0443 \u043a\u043e\u0441\u043c\u0435\u0442\u043e\u043b\u043e\u0433\u0430?<\/strong><\/p>\n<p>\u041f\u0440\u0438 \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u0438 \u0438\u043d\u044a\u0435\u043a\u0446\u0438\u0439 \u0441\u0435\u0440\u0442\u0438\u0444\u0438\u0446\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u043c\u0438 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u0438\u0441\u0442\u0430\u043c\u0438 \u0441 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u043c\u0438 \u043f\u0440\u0435\u043f\u0430\u0440\u0430\u0442\u0430\u043c\u0438 \u043e\u043d\u0438 \u043e\u0431\u044b\u0447\u043d\u043e \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u044b. \u0412\u0430\u0436\u043d\u043e \u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u044c \u0432\u0441\u0435\u043c \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0430\u0446\u0438\u044f\u043c \u0434\u043e \u0438 \u043f\u043e\u0441\u043b\u0435 \u043f\u0440\u043e\u0446\u0435\u0434\u0443\u0440\u044b.<\/p>\n<p><strong>6. \u041a\u0430\u043a \u0443\u0445\u0430\u0436\u0438\u0432\u0430\u0442\u044c \u0437\u0430 \u043a\u043e\u0436\u0435\u0439 \u043f\u043e\u0441\u043b\u0435 \u043f\u0440\u043e\u0446\u0435\u0434\u0443\u0440?<\/strong><\/p>\n<p>\u041f\u043e\u0441\u043b\u0435 \u043a\u043e\u0441\u043c\u0435\u0442\u043e\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u043f\u0440\u043e\u0446\u0435\u0434\u0443\u0440 \u0432\u0430\u0436\u043d\u043e \u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u044c \u0438\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u044f\u043c \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u0438\u0441\u0442\u0430: \u0438\u0437\u0431\u0435\u0433\u0430\u0439\u0442\u0435 \u0441\u043e\u043b\u043d\u0446\u0430, \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0439\u0442\u0435 \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u043e\u0432\u0430\u043d\u043d\u044b\u0435 \u043a\u0440\u0435\u043c\u044b \u0438 \u0443\u0432\u043b\u0430\u0436\u043d\u044f\u0439\u0442\u0435 \u043a\u043e\u0436\u0443.<\/p>\n<p><strong>7. \u041a\u0430\u043a \u0443\u0437\u043d\u0430\u0442\u044c, \u043f\u043e\u0434\u0445\u043e\u0434\u0438\u0442 \u043b\u0438 \u043c\u043d\u0435 \u043f\u0440\u043e\u0446\u0435\u0434\u0443\u0440\u0430?<\/strong><\/p>\n<p>\u041a\u043e\u043d\u0441\u0443\u043b\u044c\u0442\u0430\